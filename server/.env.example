# ===========================================
# KLS 知识库平台 - 环境配置
# ===========================================

# 服务端口
PORT=3000
NODE_ENV=development

# 数据库
DB_PATH=./data/db/kls.db

# 向量数据库 (ChromaDB)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=knowledge_base

# 本地 LLM (Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen2.5:7b

# 上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
# 支持的文件类型: pdf, txt, md, docx, xlsx, csv
ALLOWED_EXTENSIONS=pdf,txt,md,docx,xlsx,csv

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# 知识培训 (参考 OpenMAIC 风格)
TRAINING_DEFAULT_MODEL=qwen2.5:7b

# 文档分片配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 日志
LOG_LEVEL=debug
LOG_DIR=./logs
